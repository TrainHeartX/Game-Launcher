<Application x:Class="GameLauncher.BigScreen.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GameLauncher.BigScreen"
             xmlns:sharedconv="clr-namespace:GameLauncher.UI.Shared.Converters;assembly=GameLauncher.UI.Shared"
>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Converters -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters locales -->
            <local:BoolToStringConverter x:Key="BoolToStringConverter"
                                         xmlns:local="clr-namespace:GameLauncher.BigScreen.Converters"/>
            <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                       xmlns:conv="clr-namespace:GameLauncher.BigScreen.Converters"/>
            <conv:BoolToInstalledTextConverter x:Key="BoolToInstalledTextConverter"
                                               xmlns:conv="clr-namespace:GameLauncher.BigScreen.Converters"/>
            <conv:StarsConverter x:Key="StarsConverter"
                                 xmlns:conv="clr-namespace:GameLauncher.BigScreen.Converters"/>
            <conv:ValueToVisibilityConverter x:Key="ValueToVisibilityConverter"
                                             xmlns:conv="clr-namespace:GameLauncher.BigScreen.Converters"/>
            <conv:PercentToWidthConverter x:Key="PercentToWidthConverter"
                                          xmlns:conv="clr-namespace:GameLauncher.BigScreen.Converters"/>

            <!-- Shared Converters -->
            <sharedconv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <sharedconv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <sharedconv:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
            <sharedconv:PlayTimeConverter x:Key="PlayTimeConverter"/>
            <sharedconv:ImagePathConverter x:Key="ImagePathConverter"/>
            <sharedconv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <sharedconv:PlayCountToVisibilityConverter x:Key="PlayCountToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
