<Page x:Class="GameLauncher.BigScreen.Views.GameDetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="1080" d:DesignWidth="1920"
      Background="Black"
      Title="Detalles del Juego">

    <Grid>
        <!-- Background con gradiente -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Contenido principal -->
        <Grid Margin="80,50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header con título -->
            <TextBlock Grid.Row="0"
                       Text="{Binding GameTitle, FallbackValue='DETALLES DEL JUEGO'}"
                       FontSize="56"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Contenido principal -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="600"/>
                </Grid.ColumnDefinitions>

                <!-- Panel izquierdo: Información -->
                <Border Grid.Column="0"
                        Background="#1a1a2e"
                        CornerRadius="15"
                        Padding="40">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Video del juego -->
                            <Border Background="Black"
                                    Height="400"
                                    CornerRadius="10"
                                    Margin="0,0,0,30">
                                <Grid>
                                    <!-- MediaElement para reproducir video -->
                                    <MediaElement x:Name="GameVideoPlayer"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop"
                                                  Stretch="Uniform"
                                                  Volume="1"
                                                  MediaEnded="GameVideoPlayer_MediaEnded"
                                                  MediaOpened="GameVideoPlayer_MediaOpened"
                                                  MediaFailed="GameVideoPlayer_MediaFailed"/>
                                    <!-- Placeholder cuando no hay video -->
                                    <TextBlock x:Name="VideoPlaceholder"
                                               Text="📹"
                                               FontSize="120"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#495057"/>
                                </Grid>
                            </Border>

                            <!-- Información básica -->
                            <TextBlock Text="INFORMACIÓN"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#00d4ff"
                                       Margin="0,0,0,20"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Desarrollador:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GameDeveloper}" FontSize="20" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Publisher:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GamePublisher}" FontSize="20" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Género:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GameGenre}" FontSize="20" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Año:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GameYear}" FontSize="20" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Plataforma:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GamePlatform}" FontSize="20" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rating:" FontSize="20" Foreground="#adb5bd"/>
                                <TextBlock Grid.Column="1" Text="{Binding GameRating}" FontSize="24" Foreground="Gold"/>
                            </Grid>

                            <!-- Descripción -->
                            <TextBlock Text="DESCRIPCIÓN"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#00d4ff"
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="{Binding GameDescription}"
                                       FontSize="18"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       LineHeight="26"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Panel derecho: Estadísticas y acciones -->
                <Border Grid.Column="2"
                        Background="#1a1a2e"
                        CornerRadius="15"
                        Padding="40">
                    <StackPanel>
                        <!-- Estadísticas -->
                        <TextBlock Text="ESTADÍSTICAS"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#00d4ff"
                                   Margin="0,0,0,30"/>

                        <!-- Tiempo jugado -->
                        <Border Background="#2a2a3e"
                                Padding="25"
                                Margin="0,0,0,20"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="TIEMPO JUGADO"
                                           FontSize="18"
                                           Foreground="#adb5bd"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding GamePlayTime}"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Foreground="#00ff00"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Veces jugado -->
                        <Border Background="#2a2a3e"
                                Padding="25"
                                Margin="0,0,0,20"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="VECES JUGADO"
                                           FontSize="18"
                                           Foreground="#adb5bd"
                                           HorizontalAlignment="Center"/>
                                <TextBlock FontSize="48"
                                           FontWeight="Bold"
                                           Foreground="#00d4ff"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0">
                                    <Run Text="{Binding GamePlayCount, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Última vez jugado -->
                        <Border Background="#2a2a3e"
                                Padding="25"
                                Margin="0,0,0,40"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="ÚLTIMA VEZ JUGADO"
                                           FontSize="18"
                                           Foreground="#adb5bd"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding GameLastPlayed}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Estado -->
                        <TextBlock Text="ESTADO"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#00d4ff"
                                   Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="★" FontSize="32" Foreground="Gold" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding GameFavorite, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Favorito|No favorito'}"
                                       FontSize="24"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,40">
                            <TextBlock Text="✓" FontSize="32" Foreground="#00ff00" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding GameCompleted, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Completado|No completado'}"
                                       FontSize="24"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Botones de acción -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,40,0,0">
                <Button Content="▶ JUGAR"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White"
                        Padding="40,20"
                        Margin="15,0"
                        Cursor="Hand"
                        Command="{Binding LaunchGameCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#00d4ff" Offset="0"/>
                                        <GradientStop Color="#0096ff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0096ff"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="★ FAVORITO"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#FFD700"
                        Padding="40,20"
                        Margin="15,0"
                        Cursor="Hand"
                        Command="{Binding ToggleFavoriteCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="✓ COMPLETADO"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#00ff00"
                        Padding="40,20"
                        Margin="15,0"
                        Cursor="Hand"
                        Command="{Binding ToggleCompletedCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Status y controles -->
            <Grid Grid.Row="3" Margin="0,30,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status -->
                <TextBlock Grid.Row="0"
                           Text="{Binding StatusText}"
                           FontSize="20"
                           Foreground="#adb5bd"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Controles -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Border Background="#2a2a3e" Padding="20,10" Margin="10,0" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="A" FontSize="24" FontWeight="Bold" Foreground="#00ff00" Margin="0,0,10,0"/>
                            <TextBlock Text="Jugar" FontSize="20" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2a2a3e" Padding="20,10" Margin="10,0" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Y" FontSize="24" FontWeight="Bold" Foreground="#ffff00" Margin="0,0,10,0"/>
                            <TextBlock Text="Favorito" FontSize="20" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2a2a3e" Padding="20,10" Margin="10,0" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="B" FontSize="24" FontWeight="Bold" Foreground="#ff0000" Margin="0,0,10,0"/>
                            <TextBlock Text="Volver" FontSize="20" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
