<Page x:Class="GameLauncher.BigScreen.Views.SystemInfoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="1080" d:DesignWidth="1920"
      Background="Black"
      Title="Gestión de Juegos">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="GESTIÓN DE JUEGOS"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00d4ff" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar - Section Selector -->
                <Border Grid.Column="0"
                        Background="#111122"
                        CornerRadius="15"
                        Padding="20"
                        Margin="0,0,20,0">
                    <StackPanel>
                        <!-- Section 0: Hardware -->
                        <Border x:Name="Section0"
                                CornerRadius="10"
                                Padding="20,15"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSectionIndex}" Value="0">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#00d4ff" Offset="0"/>
                                                        <GradientStop Color="#0096ff" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#00d4ff" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="🔧" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Hardware" 
                                           FontSize="22" 
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Section 1: Almacenamiento -->
                        <Border x:Name="Section1"
                                CornerRadius="10"
                                Padding="20,15"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSectionIndex}" Value="1">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#00d4ff" Offset="0"/>
                                                        <GradientStop Color="#0096ff" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#00d4ff" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="💾" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Almacenamiento" 
                                           FontSize="22" 
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Section 2: Juegos Detectados -->
                        <Border x:Name="Section2"
                                CornerRadius="10"
                                Padding="20,15"
                                Background="Transparent"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSectionIndex}" Value="2">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#00d4ff" Offset="0"/>
                                                        <GradientStop Color="#0096ff" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#00d4ff" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="🎮" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Juegos Detectados" 
                                           FontSize="22" 
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Right Content Area -->
                <Border Grid.Column="1"
                        Background="#111122"
                        CornerRadius="15"
                        Padding="40">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <!-- Section 0 Content: Hardware -->
                            <StackPanel x:Name="HardwareSection"
                                        Visibility="{Binding CurrentSectionIndex, Converter={StaticResource ValueToVisibilityConverter}, ConverterParameter=0}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- CPU -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="PROCESADOR"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00d4ff"
                                               Margin="0,0,0,20"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding CpuName}"
                                               FontSize="22"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,20"/>

                                    <!-- GPU -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="GPU"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00d4ff"
                                               Margin="0,0,0,20"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding GpuName}"
                                               FontSize="22"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,20"/>

                                    <!-- RAM -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="RAM"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00d4ff"
                                               Margin="0,0,0,20"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding RamTotal}"
                                               FontSize="22"
                                               Foreground="White"
                                               Margin="0,0,0,20"/>

                                    <!-- OS -->
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="SISTEMA"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00d4ff"
                                               Margin="0,0,0,20"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding OsVersion}"
                                               FontSize="22"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,20"/>

                                    <!-- Resolution -->
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="RESOLUCIÓN"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00d4ff"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding ScreenResolution}"
                                               FontSize="22"
                                               Foreground="White"/>
                                </Grid>
                            </StackPanel>

                            <!-- Section 1 Content: Almacenamiento -->
                            <StackPanel x:Name="StorageSection"
                                        Visibility="{Binding CurrentSectionIndex, Converter={StaticResource ValueToVisibilityConverter}, ConverterParameter=1}">
                                <ItemsControl ItemsSource="{Binding Disks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1a1a2e"
                                                    CornerRadius="10"
                                                    Padding="25,20"
                                                    Margin="0,0,0,20">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Disk Letter -->
                                                    <TextBlock Grid.Row="0"
                                                               FontSize="26"
                                                               FontWeight="Bold"
                                                               Foreground="#00d4ff"
                                                               Margin="0,0,0,10">
                                                        <Run Text="DISCO "/>
                                                        <Run Text="{Binding Letter}"/>
                                                    </TextBlock>

                                                    <!-- Space Info -->
                                                    <TextBlock Grid.Row="1"
                                                               FontSize="20"
                                                               Foreground="#ced4da"
                                                               Margin="0,0,0,15">
                                                        <Run Text="{Binding FreeGB, StringFormat={}{0:F2}}"/>
                                                        <Run Text=" GB libre / "/>
                                                        <Run Text="{Binding TotalGB, StringFormat={}{0:F2}}"/>
                                                        <Run Text=" GB total"/>
                                                    </TextBlock>

                                                    <!-- Progress Bar -->
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Height="30"
                                                                Background="#0f3460"
                                                                CornerRadius="15"
                                                                Margin="0,0,15,0">
                                                            <Border x:Name="ProgressFill"
                                                                    Background="#00d4ff"
                                                                    CornerRadius="15"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Width>
                                                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                        <Binding Path="UsagePercent"/>
                                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Border>

                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="20"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{Binding UsagePercent}"/>
                                                            <Run Text="%"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Section 2 Content: Juegos Detectados -->
                            <StackPanel x:Name="GamesSection"
                                        Visibility="{Binding CurrentSectionIndex, Converter={StaticResource ValueToVisibilityConverter}, ConverterParameter=2}">
                                
                                <!-- Scanning Status -->
                                <TextBlock Text="{Binding ScanStatus}"
                                           FontSize="24"
                                           Foreground="#adb5bd"
                                           Margin="0,0,0,30"
                                           Visibility="{Binding IsScanningGames, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Scanned Disks Results -->
                                <ItemsControl ItemsSource="{Binding ScannedDisks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1a1a2e"
                                                    CornerRadius="10"
                                                    Padding="25,20"
                                                    Margin="0,0,0,20">
                                                <StackPanel>
                                                    <!-- Drive Header -->
                                                    <TextBlock FontSize="26"
                                                               FontWeight="Bold"
                                                               Foreground="#00d4ff"
                                                               Margin="0,0,0,15">
                                                        <Run Text="{Binding DriveLetter}"/>
                                                        <Run Text=" — " Foreground="#ced4da"/>
                                                        <Run Text="{Binding TotalFound}" Foreground="White"/>
                                                        <Run Text=" archivos de juego encontrados" Foreground="#ced4da"/>
                                                    </TextBlock>

                                                    <!-- Scanning Indicator -->
                                                    <TextBlock Text="Escaneando..."
                                                               FontSize="18"
                                                               Foreground="#adb5bd"
                                                               FontStyle="Italic"
                                                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                    <!-- Results -->
                                                    <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                        <!-- ROMs -->
                                                        <TextBlock FontSize="20"
                                                                   Foreground="#ced4da"
                                                                   Margin="20,0,0,5">
                                                            <Run Text="   ROMs: " FontWeight="SemiBold"/>
                                                            <Run Text="{Binding RomCount}" Foreground="White" FontWeight="Bold"/>
                                                        </TextBlock>

                                                        <!-- ROM Breakdown (if available) -->
                                                        <ItemsControl ItemsSource="{Binding RomsByConsole}"
                                                                      Margin="40,5,0,10">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock FontSize="16"
                                                                               Foreground="#adb5bd">
                                                                        <Run Text="{Binding Key}"/>
                                                                        <Run Text=": "/>
                                                                        <Run Text="{Binding Value}" Foreground="White"/>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- PC Games -->
                                                        <TextBlock FontSize="20"
                                                                   Foreground="#ced4da"
                                                                   Margin="20,5,0,0">
                                                            <Run Text="   PC: " FontWeight="SemiBold"/>
                                                            <Run Text="{Binding PcGameCount}" Foreground="White" FontWeight="Bold"/>
                                                            <Run Text=" ejecutables"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer Instructions -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <TextBlock Text="[LB/RB]"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#00d4ff"
                           Margin="0,0,10,0"/>
                <TextBlock Text="Sección"
                           FontSize="22"
                           Foreground="#ced4da"
                           Margin="0,0,40,0"/>
                <TextBlock Text="[Y]"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#00d4ff"
                           Margin="0,0,10,0"/>
                <TextBlock Text="Volver"
                           FontSize="22"
                           Foreground="#ced4da"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
