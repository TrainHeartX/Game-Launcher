<Page x:Class="GameLauncher.BigScreen.Views.PlatformFiltersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="1080" d:DesignWidth="1920"
      Background="Black"
      Title="Navegación">

    <Page.Resources>
        <SolidColorBrush x:Key="SagaCompletaBrush" Color="#00cc66"/>
        <SolidColorBrush x:Key="SemiCompletaBrush" Color="#ffaa00"/>
        <SolidColorBrush x:Key="SagaParcialBrush" Color="#ff6633"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="30,20,30,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{Binding CurrentTitle}"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="1000"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation items list -->
                    <ListBox x:Name="PlatformListBox"
                             Grid.Row="0"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             ScrollViewer.CanContentScroll="True"
                             Focusable="True">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    Padding="20,12"
                                                    Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Node icon -->
                                                    <Grid Grid.Column="0"
                                                          Width="36" Height="36"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0">
                                                        <Image x:Name="ItemLogoImage"
                                                               Source="{Binding LogoImage}"
                                                               Stretch="Uniform"
                                                               Width="36" Height="36"
                                                               Visibility="Collapsed"/>
                                                        <TextBlock x:Name="ItemIconText"
                                                                   Text="{Binding Icon}"
                                                                   FontSize="28"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Grid>

                                                    <!-- Node name - full visible, wraps if needed -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="26"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>

                                                    <!-- Platform: game count -->
                                                    <StackPanel x:Name="PlatformCount"
                                                                Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,0,0"
                                                                Visibility="Collapsed">
                                                        <TextBlock Text="{Binding GameCount, FallbackValue=0}"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   Foreground="#00d4ff"/>
                                                        <TextBlock Text=" juegos"
                                                                   FontSize="18"
                                                                   Foreground="#adb5bd"
                                                                   Margin="6,0,0,0"/>
                                                    </StackPanel>

                                                    <!-- Category indicator -->
                                                    <StackPanel x:Name="CategoryIndicator"
                                                                Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,0,0"
                                                                Visibility="Collapsed">
                                                        <TextBlock Text="{Binding ChildrenCount}"
                                                                   FontSize="20"
                                                                   Foreground="#adb5bd"/>
                                                        <TextBlock Text=" &#x25B6;"
                                                                   FontSize="24"
                                                                   Foreground="#00d4ff"
                                                                   Margin="8,0,0,0"/>
                                                    </StackPanel>

                                                    <!-- Playlist indicator -->
                                                    <StackPanel x:Name="PlaylistIndicator"
                                                                Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,0,0"
                                                                Visibility="Collapsed">
                                                        <TextBlock Text="&#x25B6;"
                                                                   FontSize="24"
                                                                   Foreground="#00d4ff"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="#00d4ff" Offset="0"/>
                                                                <GradientStop Color="#0096ff" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="ItemBorder" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#00d4ff"
                                                                              BlurRadius="30"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.8"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2a2a3e"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding NodeType}" Value="Platform">
                                                    <Setter TargetName="PlatformCount" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NodeType}" Value="Category">
                                                    <Setter TargetName="CategoryIndicator" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NodeType}" Value="Playlist">
                                                    <Setter TargetName="PlaylistIndicator" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LogoImage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                                    <Setter TargetName="ItemLogoImage" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="ItemIconText" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Saga info panel (below list, only when playlist selected) -->
                    <Border Grid.Row="1"
                            Background="#111122"
                            CornerRadius="10"
                            Padding="18,12"
                            Margin="0,6,0,0"
                            MaxHeight="500"
                            Visibility="{Binding IsPlaylistSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer x:Name="SagaInfoScroller"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- Status badge -->
                                <Border x:Name="SagaStatusBadge"
                                        CornerRadius="6"
                                        Padding="14,6"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding SagaCollectionStatus, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#00d4ff"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SagaCollectionStatus}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="Black"/>
                                </Border>

                                <!-- Stats -->
                                <WrapPanel Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F3AE;" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding SagaGameCount}" FontSize="18" FontWeight="Bold" Foreground="#00d4ff" VerticalAlignment="Center"/>
                                    <TextBlock Text=" juegos  " FontSize="14" Foreground="#adb5bd" VerticalAlignment="Center"/>

                                    <TextBlock Text="&#x1F4C5; " FontSize="16" VerticalAlignment="Center"
                                               Visibility="{Binding SagaYearRange, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding SagaYearRange}" FontSize="16" Foreground="#ced4da" VerticalAlignment="Center"
                                               Visibility="{Binding SagaYearRange, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="  " FontSize="16" VerticalAlignment="Center"
                                               Visibility="{Binding SagaYearRange, Converter={StaticResource NullToVisibilityConverter}}"/>

                                    <TextBlock Text="&#x2705; " FontSize="16" VerticalAlignment="Center"
                                               Visibility="{Binding SagaCompletionStatus, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding SagaCompletionStatus}" FontSize="16" Foreground="#ced4da" VerticalAlignment="Center"
                                               Visibility="{Binding SagaCompletionStatus, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </WrapPanel>

                                <!-- Review date -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                            Visibility="{Binding SagaReviewDate, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="Revisado: " FontSize="14" Foreground="#888"/>
                                    <TextBlock Text="{Binding SagaReviewDate}" FontSize="14" Foreground="#adb5bd"/>
                                </StackPanel>

                                <!-- Last game -->
                                <TextBlock Margin="0,0,0,6"
                                           Visibility="{Binding SagaLastGame, Converter={StaticResource NullToVisibilityConverter}}"
                                           TextWrapping="Wrap" FontSize="14">
                                    <Run Text="&#x25B6; Ultimo: " Foreground="#00d4ff"/>
                                    <Run Text="{Binding SagaLastGame, Mode=OneWay}" Foreground="#ced4da"/>
                                </TextBlock>

                                <!-- Missing games (capped height, scrolls with parent) -->
                                <StackPanel Visibility="{Binding HasMissingGames, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#x26A0; Faltantes: " FontSize="15" Foreground="#ff6633" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SagaMissingCount}" FontSize="15" FontWeight="Bold" Foreground="#ff6633"/>
                                    </StackPanel>
                                    <ScrollViewer MaxHeight="100"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding SagaMissingGames}" Margin="8,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="13" Foreground="#aaa"
                                                               TextWrapping="Wrap" Margin="0,1,0,1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#2a2a3e" Margin="0,2,0,8"
                                        Visibility="{Binding SagaDescription, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Description (no MaxHeight — outer SagaInfoScroller handles scrolling) -->
                                <TextBlock x:Name="SagaNotesText"
                                           Text="{Binding SagaDescription}"
                                           FontSize="14"
                                           Foreground="#ced4da"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Visibility="{Binding SagaDescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- RIGHT COLUMN -->
                <Grid Grid.Column="1" Margin="20,0,0,0">

                    <!-- [A] Standard layout (Platform / Category) -->
                    <Grid x:Name="StandardLayout"
                          Visibility="{Binding IsPlaylistSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="StandardVideoHost"
                                Grid.Row="0"
                                Background="#111122"
                                CornerRadius="15"
                                Padding="0"
                                ClipToBounds="True"
                                VerticalAlignment="Center"/>

                        <Border Grid.Row="1"
                                Background="#111122"
                                CornerRadius="10"
                                Padding="30,20"
                                Margin="0,15,0,0"
                                Visibility="{Binding SelectedItemNotes, Converter={StaticResource NullToVisibilityConverter}}">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedItemNotes}"
                                           FontSize="20"
                                           Foreground="#ced4da"
                                           TextWrapping="Wrap"
                                           LineHeight="30"
                                           TextAlignment="Center"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- [B] Saga/Playlist layout — VIDEO GRANDE -->
                    <Grid x:Name="SagaLayout"
                          Margin="-20,-10,-30,-10"
                          Visibility="{Binding IsPlaylistSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: VIDEO ENORME (se sale de los márgenes) -->
                        <Grid Grid.Row="0">
                            <Border x:Name="PlaylistVideoHost"
                                    Background="#111122"
                                    CornerRadius="10"
                                    ClipToBounds="True"/>

                            <!-- Saga logo overlay -->
                            <Border Background="#66000000"
                                    CornerRadius="10,0,10,0"
                                    Padding="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="12,12,0,0"
                                    MaxWidth="200"
                                    MaxHeight="120"
                                    Visibility="{Binding SagaLogoPath, Converter={StaticResource NullToVisibilityConverter}}">
                                <Image Source="{Binding SagaLogoPath, Converter={StaticResource ImagePathConverter}}"
                                       Stretch="Uniform"
                                       Opacity="0.85"/>
                            </Border>
                        </Grid>

                        <!-- Row 1: Game covers strip (horizontal scroll) -->
                        <Border Grid.Row="1"
                                Background="#111122"
                                CornerRadius="8"
                                Padding="8,4"
                                Margin="0,6,0,0"
                                Height="270">
                            <Grid>
                                <ScrollViewer x:Name="SagaCoversScroller"
                                              VerticalScrollBarVisibility="Disabled"
                                              HorizontalScrollBarVisibility="Hidden"
                                              PreviewMouseWheel="SagaCoversScroller_PreviewMouseWheel">
                                    <Border Padding="0,0,140,0">
                                    <ItemsControl ItemsSource="{Binding SagaGames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="120" Margin="4,0" VerticalAlignment="Top">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Year -->
                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding Year}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="#00d4ff"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,2"/>

                                                    <!-- Cover + overlays -->
                                                    <Grid Grid.Row="1" Width="110" Height="148">
                                                        <!-- Green glow border when completed -->
                                                        <Border CornerRadius="6"
                                                                BorderThickness="2"
                                                                BorderBrush="#00cc66"
                                                                Visibility="{Binding Completed, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#00cc66"
                                                                                  BlurRadius="12"
                                                                                  ShadowDepth="0"
                                                                                  Opacity="0.7"/>
                                                            </Border.Effect>
                                                        </Border>

                                                        <!-- Cover image -->
                                                        <Border Background="#1a1a2e"
                                                                CornerRadius="6"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding CoverImage}"
                                                                   Stretch="UniformToFill"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Completed checkmark (top-right) -->
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Background="#CC00cc66"
                                                                CornerRadius="0,6,0,6"
                                                                Padding="5,2"
                                                                Visibility="{Binding Completed, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="&#x2714;"
                                                                       FontSize="12"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Game name -->
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Name}"
                                                               FontSize="11"
                                                               Foreground="#ced4da"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               MaxHeight="30"
                                                               Margin="0,2,0,0"/>

                                                    <!-- Platform logo -->
                                                    <Image Grid.Row="3"
                                                           Source="{Binding PlatformImage}"
                                                           Height="22"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </Border>
                                </ScrollViewer>

                                <Grid Visibility="{Binding IsSagaLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Background="#AA111122">
                                    <TextBlock Text="Cargando juegos..."
                                               FontSize="20"
                                               Foreground="#adb5bd"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Shared Video Container -->
                <Grid x:Name="VideoContainer"
                      Visibility="Collapsed">
                    <MediaElement x:Name="PlatformVideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  Volume="0"
                                  Opacity="0"
                                  ScrubbingEnabled="True"
                                  MediaEnded="PlatformVideoPlayer_MediaEnded"
                                  MediaOpened="PlatformVideoPlayer_MediaOpened"
                                  MediaFailed="PlatformVideoPlayer_MediaFailed"/>

                    <Border x:Name="VideoPlaceholder"
                            Background="#1a1a2e"
                            Visibility="Visible">
                        <Grid>
                            <Image x:Name="SelectedItemImage"
                                   Source="{Binding SelectedItemImagePath, Converter={StaticResource ImagePathConverter}}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="20"
                                   Visibility="{Binding SelectedItemImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding SelectedItemImagePath, Converter={StaticResource InverseNullToVisibilityConverter}}">
                                <TextBlock Text="&#x1F3AE;"
                                           FontSize="120"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Selecciona un elemento"
                                           FontSize="24"
                                           Foreground="#495057"
                                           HorizontalAlignment="Center"
                                           Margin="0,20,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>

        <!-- Loading overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#CC000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x23F3;"
                           FontSize="72"
                           HorizontalAlignment="Center"
                           Foreground="White"/>
                <TextBlock Text="Cargando..."
                           FontSize="32"
                           Foreground="White"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
