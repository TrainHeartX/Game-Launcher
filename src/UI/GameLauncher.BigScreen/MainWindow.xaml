<Window x:Class="GameLauncher.BigScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher.BigScreen"
        mc:Ignorable="d"
        Title="GameLauncher BigScreen"
        Background="Black">

    <Grid>
        <!-- Frame para navegación entre vistas -->
        <Frame x:Name="NavigationFrame"
               NavigationUIVisibility="Hidden"
               Background="Transparent"/>

        <!-- Splash / Intro overlay -->
        <Grid x:Name="SplashOverlay">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0a0a1a" Offset="0"/>
                    <GradientStop Color="#1a1a3e" Offset="0.5"/>
                    <GradientStop Color="#0a0a1a" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- App icon / glow -->
                <Border Width="120" Height="120"
                        CornerRadius="60"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00d4ff" Offset="0"/>
                            <GradientStop Color="#0096ff" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00d4ff"
                                          BlurRadius="60"
                                          ShadowDepth="0"
                                          Opacity="0.8"/>
                    </Border.Effect>
                    <TextBlock Text="GL"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- App name -->
                <TextBlock Text="GameLauncher"
                           FontSize="72"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00d4ff"
                                          BlurRadius="30"
                                          ShadowDepth="0"
                                          Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Subtitle -->
                <TextBlock Text="BigScreen"
                           FontSize="36"
                           FontWeight="Light"
                           Foreground="#00d4ff"
                           HorizontalAlignment="Center"
                           Margin="0,-5,0,20"/>

                <!-- Version -->
                <TextBlock x:Name="SplashVersionText"
                           Text="v1.0.0"
                           FontSize="18"
                           Foreground="#6c757d"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,50"/>

                <!-- Loading indicator -->
                <StackPanel x:Name="SplashLoadingPanel" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="300"
                                 Height="3"
                                 Foreground="#00d4ff"
                                 Background="#1a1a2e"
                                 BorderThickness="0"/>
                    <TextBlock x:Name="SplashStatusText"
                               Text="Iniciando..."
                               FontSize="16"
                               Foreground="#adb5bd"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Author credit at bottom -->
            <StackPanel VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,60">
                <TextBlock FontSize="16"
                           Foreground="#6c757d"
                           HorizontalAlignment="Center">
                    <Run Text="Desarrollado por "/>
                    <Run Text="Daniel Restrepo" FontWeight="SemiBold" Foreground="#adb5bd"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
