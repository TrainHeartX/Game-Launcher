<Window x:Class="GameLauncher.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher.Desktop"
        xmlns:vm="clr-namespace:GameLauncher.Desktop.ViewModels"
        xmlns:conv="clr-namespace:GameLauncher.Desktop.Converters"
        xmlns:sharedconv="clr-namespace:GameLauncher.UI.Shared.Converters;assembly=GameLauncher.UI.Shared"
        xmlns:shared="clr-namespace:GameLauncher.UI.Shared.Controls;assembly=GameLauncher.UI.Shared"
        xmlns:enums="clr-namespace:GameLauncher.Core.Enums;assembly=GameLauncher.Core"
        mc:Ignorable="d"
        Title="GameLauncher - Gestor de Juegos Compatible con LaunchBox"
        Height="720" Width="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converters -->
        <conv:ArgbIntegerToColorConverter x:Key="ArgbToColorConverter"/>
        <sharedconv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <sharedconv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <sharedconv:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
        <sharedconv:PlayTimeConverter x:Key="PlayTimeConverter"/>
        <sharedconv:ImagePathConverter x:Key="ImagePathConverter"/>
        <sharedconv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <sharedconv:PlayCountToVisibilityConverter x:Key="PlayCountToVisibilityConverter"/>

        <!-- Estilos -->
        <Style x:Key="PanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="GameListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderBrush" Value="#ECF0F1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Barra de herramientas -->
            <RowDefinition Height="Auto"/>
            <!-- Contenido principal -->
            <RowDefinition Height="*"/>
            <!-- Barra de estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BARRA DE HERRAMIENTAS -->
        <Border Grid.Row="0" Background="#34495E" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Botones de acción -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="▶ Jugar"
                            Command="{Binding LaunchSelectedGameCommand}"
                            Padding="15,5"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Content="⭐ Favorito"
                            Command="{Binding ToggleFavoriteCommand}"
                            Padding="10,5"
                            Margin="0,0,10,0"
                            Background="#F39C12"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- Búsqueda -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="300"
                             Padding="5"
                             VerticalContentAlignment="Center"
                             FontSize="12">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchGamesCommand}"/>
                            <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding SearchAllPlatformsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Content="🔍 Buscar"
                            Command="{Binding SearchGamesCommand}"
                            Padding="10,5"
                            Margin="5,0"
                            Background="#9B59B6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Buscar en plataforma actual (Enter)"/>

                    <Button Content="🌐 Global"
                            Command="{Binding SearchAllPlatformsCommand}"
                            Padding="10,5"
                            Margin="0,0,5,0"
                            Background="#8E44AD"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Buscar en TODAS las plataformas (Ctrl+F)"/>

                    <Button Content="✖ Limpiar"
                            Command="{Binding ClearSearchCommand}"
                            Padding="10,5"
                            Background="#95A5A6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL - 3 PANELES -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Panel izquierdo: Plataformas -->
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <!-- Panel central: Juegos -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <!-- Panel derecho: Detalles -->
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- PANEL IZQUIERDO: Plataformas / Playlists -->
            <Border Grid.Column="0" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,0">
                        <Button Content="Plataformas"
                                Command="{Binding ShowPlatformsCommand}"
                                Padding="10,5" Margin="0,0,5,0"
                                FontWeight="SemiBold" FontSize="11"
                                Background="{Binding ShowPlatformsSection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Background}"
                                Foreground="#2C3E50"
                                BorderBrush="#BDC3C7" BorderThickness="1"
                                Cursor="Hand"/>
                        <Button Content="Playlists"
                                Command="{Binding ShowPlaylistsCommand}"
                                Padding="10,5"
                                FontWeight="SemiBold" FontSize="11"
                                Foreground="#2C3E50"
                                BorderBrush="#BDC3C7" BorderThickness="1"
                                Cursor="Hand"/>
                    </StackPanel>

                    <!-- PlatformTreeView (categories + quick filters) -->
                    <shared:PlatformTreeView Grid.Row="1"
                                             DataContext="{Binding}"
                                             Visibility="{Binding ShowPlatformsSection, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Playlists List -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Playlists}"
                             Background="White"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Margin="5"
                             Visibility="{Binding ShowPlaylistsSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.LoadGamesForPlaylistCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#212529"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- GridSplitter izquierdo -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#BDC3C7"/>

            <!-- PANEL CENTRAL: Lista de Juegos -->
            <Border Grid.Column="2" Background="White" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <!-- Title + count row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="JUEGOS" Style="{StaticResource PanelHeaderStyle}" Margin="0"/>
                            <TextBlock Text="{Binding FilteredGames.Count, StringFormat=' ({0})'}"
                                       FontSize="12" Foreground="#7F8C8D"
                                       VerticalAlignment="Bottom" Margin="6,0,0,1"/>
                            <!-- Sort status -->
                            <TextBlock Text="{Binding SortStatusText}"
                                       FontSize="10" Foreground="#3498DB"
                                       VerticalAlignment="Bottom" Margin="12,0,0,1"
                                       Visibility="{Binding SortStatusText, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Sort / Filter toolbar -->
                        <WrapPanel Orientation="Horizontal">
                            <!-- Sort field -->
                            <TextBlock Text="Ordenar:" FontSize="11" Foreground="#7F8C8D"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox Width="130" FontSize="11" Margin="0,0,6,4"
                                      SelectedValue="{Binding CurrentSortField, Mode=TwoWay}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Título"        Tag="Title"/>
                                <ComboBoxItem Content="Último jugado" Tag="LastPlayed"/>
                                <ComboBoxItem Content="Veces jugado" Tag="PlayCount"/>
                                <ComboBoxItem Content="Tiempo total"  Tag="PlayTime"/>
                                <ComboBoxItem Content="Año"           Tag="ReleaseDate"/>
                                <ComboBoxItem Content="Rating"         Tag="StarRating"/>
                                <ComboBoxItem Content="Desarrollador" Tag="Developer"/>
                                <ComboBoxItem Content="Género"         Tag="Genre"/>
                                <ComboBoxItem Content="Fecha agregado" Tag="DateAdded"/>
                            </ComboBox>
                            <Button Content="{Binding SortDescending, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=▼|▲}"
                                    Command="{Binding ToggleSortDirectionCommand}"
                                    Padding="8,2" Margin="0,0,10,4"
                                    FontSize="12" FontWeight="Bold"
                                    Background="#2C3E50" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    ToolTip="Cambiar dirección de orden"/>

                            <!-- Filter presets -->
                            <TextBlock Text="Filtro:" FontSize="11" Foreground="#7F8C8D"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Button Content="Todos"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.All}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#2C3E50" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="★ Favoritos"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.Favorites}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#F39C12" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="✓ Completados"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.Completed}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#27AE60" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="💾 Instalados"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.Installed}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#3498DB" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="🕒 Recientes"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.RecentlyPlayed}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#8E44AD" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="○ No jugados"
                                    Command="{Binding SetFilterCommand}"
                                    CommandParameter="{x:Static enums:GameFilter.NeverPlayed}"
                                    Padding="8,2" Margin="0,0,3,4" FontSize="11"
                                    Background="#95A5A6" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Loading Overlay -->
                    <Border Grid.Row="1"
                            Background="#80000000"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            Panel.ZIndex="999">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⏳ Cargando..."
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Command="{Binding ExportToAndroidCommand}" 
                            Margin="0,0,5,0"
                            ToolTip="Exportar juegos seleccionados a Android (Sincronizar ROMs y Partidas)"
                            Background="#2e7d32" Foreground="White"
                            Padding="10,5" BorderThickness="0" Cursor="Hand" FontWeight="Bold">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📱" FontFamily="Segoe UI Emoji" Margin="0,0,5,0"/>
                            <TextBlock Text="Exportar a Android"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Lista de juegos -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding FilteredGames}"
                             SelectedItem="{Binding SelectedGame}"
                             ItemContainerStyle="{StaticResource GameListItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Imagen del juego -->
                                    <Border Grid.Column="0"
                                            Width="60"
                                            Height="80"
                                            Margin="0,0,10,0"
                                            Background="#F5F5F5"
                                            BorderBrush="#BDC3C7"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <Grid>
                                            <Image Source="{Binding CoverImage}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding CoverImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="🎮"
                                                       FontSize="30"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#BDC3C7"
                                                       Visibility="{Binding CoverImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="Bold"
                                                       FontSize="14"/>

                                            <TextBlock Text="⭐"
                                                       Margin="10,0,0,0"
                                                       Visibility="{Binding Favorite, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <TextBlock Text="✓"
                                                       Margin="5,0,0,0"
                                                       Foreground="#27AE60"
                                                       FontWeight="Bold"
                                                       Visibility="{Binding Completed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="11"
                                                   Foreground="#7F8C8D"
                                                   Margin="0,2,0,0"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Genre}"
                                                       FontSize="10"
                                                       Foreground="#95A5A6"/>
                                            <TextBlock Text=" • "
                                                       FontSize="10"
                                                       Foreground="#95A5A6"
                                                       Visibility="{Binding Genre, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding PlayTime, Converter={StaticResource PlayTimeConverter}}"
                                                       FontSize="10"
                                                       Foreground="#3498DB"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlayCount, StringFormat='🎮 {0}'}"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="#7F8C8D"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- GridSplitter derecho -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#BDC3C7"/>

            <!-- PANEL DERECHO: Detalles del Juego -->
            <Border Grid.Column="4" Background="#ECF0F1" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DETALLES" Style="{StaticResource PanelHeaderStyle}"/>

                        <!-- Si hay juego seleccionado -->
                        <StackPanel Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisibilityConverter}}">
                            <!-- Video del juego (gameplay) -->
                            <Border Margin="0,0,0,10" Background="Black" CornerRadius="5"
                                    Visibility="{Binding SelectedGameVideoUri, Converter={StaticResource NullToVisibilityConverter}}">
                                <MediaElement x:Name="GameVideoPlayer"
                                              Width="350" Height="197"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Stop"
                                              Stretch="Uniform"
                                              MediaEnded="GameVideoPlayer_MediaEnded"
                                              MediaOpened="GameVideoPlayer_MediaOpened"
                                              Volume="1"/>
                            </Border>

                            <!-- Imagen grande del juego (Box Art) -->
                            <Border Width="200" Height="265" Margin="0,0,0,15" Background="#F5F5F5" BorderBrush="#BDC3C7" BorderThickness="2" CornerRadius="5">
                                <Grid>
                                    <Image Source="{Binding SelectedGame.CoverImage}" Stretch="Uniform" Margin="5"
                                           Visibility="{Binding SelectedGame.CoverImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="🎮" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#BDC3C7"
                                               Visibility="{Binding SelectedGame.CoverImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                </Grid>
                            </Border>

                            <!-- Título -->
                            <TextBlock Text="{Binding SelectedGame.Title}" FontSize="15" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <!-- INFORMACIÓN BÁSICA -->
                            <TextBlock Text="INFORMACIÓN" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <Border Background="White" Padding="8" CornerRadius="3" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Plataforma: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Platform}" FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Desarrollador: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Developer}" FontSize="10" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Publisher: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Publisher}" FontSize="10" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Género: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Genre}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Fecha: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.FormattedReleaseDate}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Región: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Region}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Serie: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Series}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Versión: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Version}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Modo de Juego: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.PlayMode}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Max Jugadores: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.MaxPlayers}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Estado: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.Status}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Tipo Release: " FontSize="10" Foreground="#7F8C8D" Width="90"/>
                                        <TextBlock Text="{Binding SelectedGame.ReleaseType}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- VALORACIONES -->
                            <TextBlock Text="VALORACIONES" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <Border Background="White" Padding="8" CornerRadius="3" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Comunidad" FontSize="9" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding SelectedGame.CommunityStarRating, StringFormat='{}{0:F1} ⭐'}" FontSize="14" FontWeight="Bold" Foreground="#E67E22"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Tu Valoración" FontSize="9" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding SelectedGame.StarRatingFloat, StringFormat='{}{0:F1} ⭐'}" FontSize="14" FontWeight="Bold" Foreground="#F39C12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ESTADÍSTICAS -->
                            <TextBlock Text="ESTADÍSTICAS" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <Border Background="White" Padding="8" CornerRadius="3" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Veces jugado" FontSize="9" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding SelectedGame.PlayCount}" FontSize="18" FontWeight="Bold" Foreground="#3498DB"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Tiempo total" FontSize="9" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding SelectedGame.FormattedPlayTime}" FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,0,0,3">
                                        <TextBlock Text="Añadido: " FontSize="10" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding SelectedGame.DateAdded, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,3">
                                        <TextBlock Text="Modificado: " FontSize="10" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding SelectedGame.DateModified, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Última vez jugado: " FontSize="10" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding SelectedGame.LastPlayed, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ESTADO -->
                            <TextBlock Text="ESTADO" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <Border Background="White" Padding="8" CornerRadius="3" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding SelectedGame.Favorite}" Content="⭐ Favorito" FontSize="10" Margin="0,0,0,3"/>
                                    <CheckBox IsChecked="{Binding SelectedGame.Completed}" Content="✓ Completado" FontSize="10" Margin="0,0,0,3"/>
                                    <CheckBox IsChecked="{Binding SelectedGame.Broken}" Content="⚠ Roto" FontSize="10" Margin="0,0,0,3"/>
                                    <CheckBox IsChecked="{Binding SelectedGame.Hide}" Content="🙈 Oculto" FontSize="10" Margin="0,0,0,3"/>
                                    <CheckBox IsChecked="{Binding SelectedGame.Portable}" Content="💾 Portable" FontSize="10"/>
                                </StackPanel>
                            </Border>

                            <!-- INFORMACIÓN TÉCNICA -->
                            <TextBlock Text="INFORMACIÓN TÉCNICA" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <Border Background="White" Padding="8" CornerRadius="3" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Ruta de Aplicación:" FontSize="9" Foreground="#7F8C8D"/>
                                    <TextBlock Text="{Binding SelectedGame.ApplicationPath}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                    <TextBlock Text="Emulador:" FontSize="9" Foreground="#7F8C8D"/>
                                    <TextBlock Text="{Binding SelectedGame.Emulator}" FontSize="9" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- DESCRIPCIÓN / NOTAS -->
                            <TextBlock Text="DESCRIPCIÓN" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,5,0,5" Visibility="{Binding SelectedGame.Notes, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <Border Background="White" Padding="10" CornerRadius="3" Margin="0,0,0,10" Visibility="{Binding SelectedGame.Notes, Converter={StaticResource NullToVisibilityConverter}}">
                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding SelectedGame.Notes}" TextWrapping="Wrap" FontSize="10" LineHeight="16"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <!-- Si NO hay juego seleccionado -->
                        <TextBlock Text="Selecciona un juego para ver sus detalles"
                                   Foreground="#95A5A6"
                                   FontStyle="Italic"
                                   TextAlignment="Center"
                                   Margin="0,50,0,0"
                                   Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- BARRA DE ESTADO -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="White"
                           FontSize="11"/>

                <!-- Indicador de caché -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0">
                    <TextBlock Text="..."
                               Foreground="#F39C12"
                               FontWeight="Bold"
                               FontSize="11"
                               Margin="0,0,5,0"
                               Visibility="{Binding IsCaching, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding CacheStatusText}"
                               Foreground="#2ECC71"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="GameLauncher v0.4.0-alpha"
                           Foreground="#95A5A6"
                           FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
