<UserControl x:Class="GameLauncher.UI.Shared.Controls.GameGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <!-- Toggle entre Grid y List View -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Vista:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#495057"/>

                <ToggleButton x:Name="GridViewToggle"
                              Width="32" Height="32"
                              Margin="5,0"
                              IsChecked="True"
                              ToolTip="Vista Grid">
                    <Path Data="M0,0 L8,0 L8,8 L0,8 Z M10,0 L18,0 L18,8 L10,8 Z M0,10 L8,10 L8,18 L0,18 Z M10,10 L18,10 L18,18 L10,18 Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          Stretch="Uniform" Width="16" Height="16"/>
                </ToggleButton>

                <ToggleButton x:Name="ListViewToggle"
                              Width="32" Height="32"
                              Margin="5,0"
                              IsChecked="False"
                              ToolTip="Vista Lista">
                    <Path Data="M0,0 L20,0 M0,6 L20,6 M0,12 L20,12 M0,18 L20,18"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          StrokeThickness="2" Stretch="Uniform" Width="16" Height="16"/>
                </ToggleButton>

                <Separator Margin="10,0" Width="1" Background="#dee2e6"/>

                <TextBlock Text="Tamaño:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#495057"/>
                <Slider x:Name="ThumbnailSizeSlider"
                        Width="100"
                        Minimum="100" Maximum="300"
                        Value="150"
                        VerticalAlignment="Center"
                        ToolTip="Tamaño de thumbnails"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <!-- Grid View -->
            <ScrollViewer x:Name="GridScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsChecked, ElementName=GridViewToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl x:Name="GamesGrid" ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="10"
                                    Background="White"
                                    BorderBrush="#dee2e6"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Width="{Binding Value, ElementName=ThumbnailSizeSlider}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Title}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#0096ff" ShadowDepth="0" BlurRadius="10" Opacity="0.5"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Box Art -->
                                    <Border Grid.Row="0" Background="#f8f9fa" CornerRadius="8,8,0,0">
                                        <Image Source="{Binding BoxFrontPath, Converter={StaticResource ImagePathConverter}}"
                                               Stretch="Uniform"
                                               Margin="5"/>
                                    </Border>

                                    <!-- Favorite Star Overlay -->
                                    <Path Grid.Row="0"
                                          Data="M12,2 L15,9 L22,10 L17,15 L18,22 L12,18 L6,22 L7,15 L2,10 L9,9 Z"
                                          Fill="#FFD700"
                                          Width="24" Height="24"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Margin="5"
                                          Visibility="{Binding Favorite, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <!-- Title -->
                                    <Border Grid.Row="1"
                                            Background="White"
                                            Padding="8"
                                            CornerRadius="0,0,8,8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Foreground="#212529"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- List View -->
            <ScrollViewer x:Name="ListScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsChecked, ElementName=ListViewToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid x:Name="GamesList"
                          ItemsSource="{Binding Games}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowHeight="40"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True">

                    <DataGrid.Columns>
                        <!-- Favorite Icon -->
                        <DataGridTemplateColumn Header="⭐" Width="30">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Path Data="M12,2 L15,9 L22,10 L17,15 L18,22 L12,18 L6,22 L7,15 L2,10 L9,9 Z"
                                          Fill="#FFD700"
                                          Width="16" Height="16"
                                          Visibility="{Binding Favorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Title -->
                        <DataGridTextColumn Header="Título"
                                            Binding="{Binding Title}"
                                            Width="250"/>

                        <!-- Platform -->
                        <DataGridTextColumn Header="Plataforma"
                                            Binding="{Binding Platform}"
                                            Width="120"/>

                        <!-- Developer -->
                        <DataGridTextColumn Header="Desarrollador"
                                            Binding="{Binding Developer}"
                                            Width="150"/>

                        <!-- Genre -->
                        <DataGridTextColumn Header="Género"
                                            Binding="{Binding Genre}"
                                            Width="100"/>

                        <!-- Release Date -->
                        <DataGridTextColumn Header="Año"
                                            Binding="{Binding ReleaseDate, StringFormat=yyyy}"
                                            Width="60"/>

                        <!-- Play Count -->
                        <DataGridTextColumn Header="Jugado"
                                            Binding="{Binding PlayCount}"
                                            Width="70"/>

                        <!-- Play Time -->
                        <DataGridTextColumn Header="Tiempo"
                                            Binding="{Binding PlayTime, Converter={StaticResource PlayTimeConverter}}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Grid>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Games.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M13,17 L11,17 L11,15 L13,15 L13,17 Z M13,13 L11,13 L11,7 L13,7 L13,13 Z"
                  Fill="#6c757d" Width="64" Height="64" Margin="0,0,0,20"/>
            <TextBlock Text="No hay juegos para mostrar"
                       FontSize="18"
                       Foreground="#6c757d"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Selecciona una plataforma del panel izquierdo"
                       FontSize="14"
                       Foreground="#adb5bd"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
