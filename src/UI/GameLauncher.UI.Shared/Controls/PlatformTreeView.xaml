<UserControl x:Class="GameLauncher.UI.Shared.Controls.PlatformTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:conv="clr-namespace:GameLauncher.UI.Shared.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="250">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>
    <Grid Background="#f8f9fa">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#dee2e6"
                BorderThickness="0,0,0,1"
                Padding="15,12">
            <StackPanel>
                <TextBlock Text="PLATAFORMAS"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#212529"/>
                <TextBlock Text="{Binding TotalPlatforms, StringFormat='{}{0} plataformas'}"
                           FontSize="11"
                           Foreground="#6c757d"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Recursive TreeView -->
        <TreeView Grid.Row="1"
                  x:Name="PlatformsTree"
                  ItemsSource="{Binding PlatformCategories}"
                  BorderThickness="0"
                  Background="Transparent"
                  Padding="5">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Padding" Value="0,1"/>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <Border x:Name="NodeBorder"
                            Padding="8,6"
                            Margin="2,1"
                            CornerRadius="6"
                            Cursor="Hand"
                            ToolTip="{Binding Name}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                <i:InvokeCommandAction
                                    Command="{Binding DataContext.SelectNavigationNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e9ecef"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#0096ff"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Platform Logo (only for platforms with logo) -->
                            <Border x:Name="LogoBox"
                                    Grid.Column="0"
                                    Width="24" Height="24"
                                    Background="#ffffff"
                                    CornerRadius="4"
                                    Margin="0,0,8,0"
                                    Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibilityConverter}}">
                                <Image Source="{Binding LogoPath, Converter={StaticResource ImagePathConverter}}"
                                       Stretch="Uniform"
                                       Margin="2"/>
                            </Border>

                            <!-- Text Icon (for nodes without logo) -->
                            <TextBlock x:Name="IconText"
                                       Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>

                            <!-- Node Name -->
                            <TextBlock x:Name="NameText"
                                       Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="13"
                                       Foreground="#212529"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>

                            <!-- Children count (for categories) -->
                            <TextBlock x:Name="ChildrenCount"
                                       Grid.Column="2"
                                       Text="{Binding Children.Count, StringFormat=' ({0})'}"
                                       FontSize="11"
                                       Foreground="#6c757d"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <!-- Game count badge (for platforms) -->
                            <Border x:Name="GameCountBadge"
                                    Grid.Column="2"
                                    Background="#6c757d"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="GameCountText"
                                           Text="{Binding GameCount}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </Grid>
                    </Border>

                    <HierarchicalDataTemplate.Triggers>
                        <!-- Category node styling -->
                        <DataTrigger Binding="{Binding NodeType}" Value="Category">
                            <Setter TargetName="NameText" Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="NameText" Property="Foreground" Value="#495057"/>
                            <Setter TargetName="ChildrenCount" Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                        <!-- Platform node styling -->
                        <DataTrigger Binding="{Binding NodeType}" Value="Platform">
                            <Setter TargetName="GameCountBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                        <!-- Selected state text styling -->
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                            <Setter TargetName="NameText" Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="GameCountBadge" Property="Background" Value="White"/>
                            <Setter TargetName="GameCountText" Property="Foreground" Value="#0096ff"/>
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Quick Filters (Bottom) -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#dee2e6"
                BorderThickness="0,1,0,0"
                Padding="15,10">
            <StackPanel>
                <TextBlock Text="FILTROS RÁPIDOS"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#6c757d"
                           Margin="0,0,0,8"/>

                <Button Content="⭐ Favoritos"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,0,5"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="#dee2e6"
                        Cursor="Hand"
                        Command="{Binding ShowFavoritesCommand}"/>

                <Button Content="🕒 Recientes"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,0,5"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="#dee2e6"
                        Cursor="Hand"
                        Command="{Binding ShowRecentlyPlayedCommand}"/>

                <Button Content="✅ Completados"
                        FontSize="12"
                        Padding="10,6"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="#dee2e6"
                        Cursor="Hand"
                        Command="{Binding ShowCompletedCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
