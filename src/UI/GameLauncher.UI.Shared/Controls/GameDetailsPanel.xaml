<UserControl x:Class="GameLauncher.UI.Shared.Controls.GameDetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="350">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#f8f9fa">
        <StackPanel Margin="15" DataContext="{Binding SelectedGame}">
            <!-- No game selected state -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,100,0,0"
                        Visibility="{Binding Converter={StaticResource InverseNullToVisibilityConverter}}">
                <Path Data="M12,2 C17.52,2 22,6.48 22,12 C22,17.52 17.52,22 12,22 C6.48,22 2,17.52 2,12 C2,6.48 6.48,2 12,2 Z M12,7 C9.24,7 7,9.24 7,12 C7,14.76 9.24,17 12,17 C14.76,17 17,14.76 17,12 C17,9.24 14.76,7 12,7 Z"
                      Fill="#6c757d" Width="80" Height="80" Margin="0,0,0,20"/>
                <TextBlock Text="Selecciona un juego"
                           FontSize="16"
                           Foreground="#6c757d"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Game details (when game is selected) -->
            <StackPanel Visibility="{Binding Converter={StaticResource NullToVisibilityConverter}}">
                <!-- Box Art -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,15">
                    <Image Source="{Binding BoxFrontPath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="Uniform"
                           MaxHeight="400"/>
                </Border>

                <!-- Title Section -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="{Binding Platform}"
                                   FontSize="14"
                                   Foreground="#6c757d"
                                   Margin="0,0,0,10"/>

                        <!-- Favorite and Completed Badges -->
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#FFD700"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding Favorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,2 L15,9 L22,10 L17,15 L18,22 L12,18 L6,22 L7,15 L2,10 L9,9 Z"
                                          Fill="White" Width="12" Height="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="Favorito" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#28a745"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Visibility="{Binding Completed, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M9,16.2 L4.8,12 L3.4,13.4 L9,19 L21,7 L19.6,5.6 Z"
                                          Fill="White" Width="12" Height="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="Completado" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Game Info -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="INFORMACIÓN"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#6c757d"
                                   Margin="0,0,0,10"/>

                        <!-- Developer -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desarrollador:" FontSize="13" Foreground="#6c757d" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Developer}" FontSize="13" Foreground="#212529" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Publisher -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Publisher:" FontSize="13" Foreground="#6c757d" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Publisher}" FontSize="13" Foreground="#212529" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Genre -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Género:" FontSize="13" Foreground="#6c757d" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Genre}" FontSize="13" Foreground="#212529" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Release Date -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lanzamiento:" FontSize="13" Foreground="#6c757d" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding ReleaseDate, StringFormat=d}" FontSize="13" Foreground="#212529"/>
                        </Grid>

                        <!-- Rating -->
                        <Grid Margin="0,0,0,8" Visibility="{Binding Rating, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rating:" FontSize="13" Foreground="#6c757d" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Rating}" FontSize="13" Foreground="#212529"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Play Statistics -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15"
                        Visibility="{Binding PlayCount, Converter={StaticResource PlayCountToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="ESTADÍSTICAS"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#6c757d"
                                   Margin="0,0,0,10"/>

                        <!-- Play Time -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12.5,7 L11,7 L11,13 L16.2,16.2 L17,14.9 L12.5,12.2 Z"
                                  Fill="#0096ff" Width="16" Height="16" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tiempo Jugado" FontSize="11" Foreground="#6c757d"/>
                                <TextBlock Text="{Binding PlayTime, Converter={StaticResource PlayTimeConverter}}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#0096ff"/>
                            </StackPanel>
                        </Grid>

                        <!-- Play Count -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="M8,5 L8,19 L19,12 Z"
                                  Fill="#00d4ff" Width="16" Height="16" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Veces Jugado" FontSize="11" Foreground="#6c757d"/>
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#00d4ff">
                                    <Run Text="{Binding PlayCount, Mode=OneWay}"/>
                                    <Run Text=" veces" FontSize="14" FontWeight="Normal"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Last Played -->
                        <Grid Visibility="{Binding LastPlayed, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="M19,3 L18,3 L18,1 L16,1 L16,3 L8,3 L8,1 L6,1 L6,3 L5,3 C3.89,3 3,3.9 3,5 L3,19 C3,20.1 3.89,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 Z M19,19 L5,19 L5,8 L19,8 L19,19 Z"
                                  Fill="#28a745" Width="16" Height="16" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Último Juego" FontSize="11" Foreground="#6c757d"/>
                                <TextBlock Text="{Binding LastPlayed, StringFormat=g}"
                                           FontSize="13"
                                           Foreground="#28a745"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Description -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Visibility="{Binding Overview, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="DESCRIPCIÓN"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#6c757d"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Overview}"
                                   FontSize="13"
                                   Foreground="#495057"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
